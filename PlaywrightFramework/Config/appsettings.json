{
  "TestSettings": {
    "// INSTRUCTIONS": "Change BaseUrl to point to your application. All tests will run against this URL.",

    "BaseUrl": "https://the-internet.herokuapp.com",

    "Browser": {
      "Type": "Chromium",
      "Headless": true,
      "SlowMo": 0,
      "Timeout": 30000,
      "ViewportWidth": 1920,
      "ViewportHeight": 1080
    },

    "Credentials": {
      "Username": "tomsmith",
      "Password": "SuperSecretPassword!"
    },

    "EntraAuth": {
      "Enabled": false,
      "TenantId": "your-tenant-id",
      "ClientId": "your-client-id",
      "Username": "user@yourdomain.onmicrosoft.com",
      "Password": "your-password",
      "MfaSecret": "",
      "StorageStatePath": ".auth/entra-state.json"
    },

    "SelfHealing": {
      "Enabled": true,
      "MaxRetries": 3,
      "LogHealedLocators": true,
      "HealingReportPath": "TestResults/healing-report.json"
    },

    "Reporting": {
      "OutputDirectory": "TestResults",
      "ScreenshotOnFailure": true,
      "TraceOnFailure": true,
      "AutoGenerateReport": true
    },

    "Notification": {
      "Enabled": false,
      "SmtpHost": "smtp.gmail.com",
      "SmtpPort": 587,
      "SmtpUsername": "your-email@gmail.com",
      "SmtpPassword": "your-app-password",
      "UseSsl": true,
      "FromAddress": "your-email@gmail.com",
      "FromName": "Playwright Test Automation",
      "Recipients": [
        "leader1@company.com",
        "leader2@company.com"
      ]
    }
  }
}
